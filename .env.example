# Server
PORT=3000

# Database (docker-compose 기본값 — 변경 불필요)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=postgres

# JWT — 32자 이상의 랜덤 문자열로 교체 필요
# 생성 예시: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-32-chars
JWT_ACCESS_EXPIRES=604800
JWT_REFRESH_EXPIRES_SEC=604800

# Kakao OAuth — https://developers.kakao.com/ 에서 앱 등록 후 발급
# 로컬 테스트만 한다면 임의의 값으로도 서버 실행은 가능
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_CALLBACK_URL=http://localhost:3000/auth/kakao/callback

# Frontend URL (CORS + OAuth 리다이렉트)
FRONTEND_URL=http://localhost:8081

# OpenAI — https://platform.openai.com/api-keys 에서 발급
# TODO: 실제 키 값을 .env에 입력하세요
OPENAI_API_KEY=sk-...
